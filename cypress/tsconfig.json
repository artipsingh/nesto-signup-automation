{
    "$schema": "https://www.schemastore.org/tsconfig",
    "compilerOptions": {
        "target": "es2020",
        "module": "es2020",
        "moduleResolution": "node",
        "lib": [
            "es2020",
            "dom"
        ],
        "types": [
            "cypress",
            "node"
        ],
        "strict": true,
        "esModuleInterop": true
    },
    "include": [
        "**/*.ts"
    ]
}