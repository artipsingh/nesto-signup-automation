{
  "name": "nesto-signup-automation",
  "version": "1.0.0",
  "description": "cypress automation for the nesto login flow",
  "homepage": "https://github.com/artipsingh/nesto-signup-automation#readme",
  "bugs": {
    "url": "https://docs.google.com/spreadsheets/d/1wHeoHHBcTfsOx23fMY2TuLEQkQ26nJyhYUNymospNys/edit?gid=0#gid=0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/artipsingh/nesto-signup-automation.git"
  },
  "license": "ISC",
  "author": "Arti P Singh",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:run:createUser": "cypress run --spec 'cypress/e2e/signup.createUser.cy.ts'",
    "cy:run:positive": "cypress run --spec 'cypress/e2e/signup.positive.cy.ts'",
    "cy:run:negative": "cypress run --spec 'cypress/e2e/signup.negative.cy.ts'",
    "lint": "eslint 'cypress/**/*.ts'",
    "lint:fix": "eslint 'cypress/**/*.ts' --fix",
    "format": "prettier --write 'cypress/**/*.ts'",
    "format:check": "prettier --check 'cypress/**/*.ts'"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@tsconfig/cypress": "^1.0.5",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "axe-core": "^4.11.1",
    "cypress": "^15.12.0",
    "cypress-axe": "^1.7.0",
    "dotenv": "^17.3.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-cypress": "^6.2.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  }
}
